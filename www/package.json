{
  "name": "world-explorer",
  "version": "2.0.0",
  "description": "一款专为 3-6 岁幼儿设计的世界国旗探索游戏，让孩子在游戏中认识世界各国国旗、学习地理知识。",
  "main": "index.html",
  "scripts": {
    "cap:init": "cap init",
    "cap:add:ios": "cap add ios",
    "cap:sync": "cap sync",
    "cap:open:ios": "cap open ios",
    "build:ios": "cap sync ios && cap open ios"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LedesmaYoung/world-explorer-app.git"
  },
  "keywords": ["kids", "education", "flags", "geography", "game"],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/LedesmaYoung/world-explorer-app/issues"
  },
  "homepage": "https://github.com/LedesmaYoung/world-explorer-app#readme",
  "dependencies": {
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "jszip": "^3.10.1",
    "xmldom": "^0.6.0"
  }
}
